{
  "private": true,
  "license": "MIT",
  "author": "Naoto Ikeno",
  "type": "module",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "pnpm run \"/check:.*/\"",
    "check:type": "pnpm run -r typecheck",
    "check:lint": "oxlint --type-aware",
    "check:fmt": "oxfmt --check .",
    "fix": "pnpm run \"/fix:.*/\"",
    "fix:lint": "oxlint --fix --type-aware",
    "fix:fmt": "oxfmt --write .",
    "build": "pnpm run -r build",
    "start-emulator": "docker build firebase-emulator && docker run -p 60000:60000 -p 60001:60001 -d --rm -it $(docker build -q firebase-emulator)"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.0"
}
