{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "plugins": ["biome-plugins/no-type-assertion.grit"],
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": { "useLiteralKeys": "off", "noForEach": "off" },
      "style": { "noParameterProperties": "off" },
      "correctness": { "noUndeclaredDependencies": "off" }
    }
  },
  "formatter": { "enabled": true, "indentStyle": "space", "lineWidth": 100, "expand": "never" },
  "javascript": { "formatter": { "quoteStyle": "single" } },
  "overrides": [
    {
      "includes": ["**/*.test.ts"],
      "linter": {
        "enabled": true,
        "rules": { "style": { "noNonNullAssertion": "off" }, "performance": {} }
      }
    },
    {
      "includes": ["**/vitest.config.ts", "vitest.shared.ts"],
      "linter": {
        "enabled": true,
        "rules": {
          "style": { "noNonNullAssertion": "off", "noDefaultExport": "off" },
          "correctness": { "noNodejsModules": "off" }
        }
      }
    },
    {
      "includes": ["examples/**/*.ts"],
      "linter": { "enabled": true, "rules": { "suspicious": { "noConsole": "off" } } }
    }
  ]
}
