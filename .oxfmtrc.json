{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "objectWrap": "collapse",
  "experimentalSortImports": {
    "groups": [
      ["side-effect"],
      ["builtin", "external", "type-external"],
      [
        "internal",
        "type-internal",
        "parent",
        "type-parent",
        "sibling",
        "type-sibling",
        "index",
        "type-index"
      ]
    ]
  }
}
